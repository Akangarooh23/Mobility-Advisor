      "id": "6a216f28-d7bd-403e-b0ac-c81854a46843",
      "name": "When Executed by Another Workflow"
    },
    {
      "parameters": {
        "jsCode": "const items = [];\nconst now = new Date().toISOString();\n\nconst fuelMap = {\n  1040: 'Diesel', 1041: 'Gasolina', 1042: 'Eléctrico',\n  1043: 'Híbrido enchufable', 1044: 'Gas', 1039: 'Híbrido', 1046: 'Híbrido'\n};\nconst gearMap = { 1138: 'Manual', 1139: 'Automatica', 1140: 'Automatica', 1141: 'Automatica' };\n\nfunction normalizeTraction(raw) {\n  var s = String(raw || '').toLowerCase();\n  if (!s) return '';\n  if (s.indexOf('4x4') !== -1 || s.indexOf('4wd') !== -1 || s.indexOf('awd') !== -1 || s.indexOf('total') !== -1 || s.indexOf('integral') !== -1) return '4x4';\n  if (s.indexOf('tras') !== -1 || s.indexOf('rwd') !== -1 || s.indexOf('rear') !== -1) return 'Trasera';\n  if (s.indexOf('del') !== -1 || s.indexOf('fwd') !== -1 || s.indexOf('front') !== -1) return 'Delantera';\n  return '';\n}\n\nfunction normalizeLabel(raw) {\n  var s = String(raw || '').toLowerCase().trim();\n  if (!s) return '';\n  if (s === 'zero' || s === 'cero' || s === '0' || s.indexOf('0 emis') !== -1) return '0 Emisiones';\n  if (s === 'eco' || s === 'e') return 'ECO';\n  if (s === 'c' || s === 'green') return 'C';\n  if (s === 'b' || s === 'yellow') return 'B';\n  return String(raw).toUpperCase();\n}\n\nfor (const input of $input.all()) {\n  const cars = input.json?.data?.searchAdV9AdsV2?.data || [];\n\n  for (const car of cars) {\n    const price = car.offerPrice\n      ? Math.round(car.offerPrice.amountMinorUnits / car.offerPrice.conversionMajor)\n      : null;\n    const monthly = car.monthlyPayment\n      ? Math.round(car.monthlyPayment.amountMinorUnits / car.monthlyPayment.conversionMajor)\n      : null;\n\n    const city     = car.esBranch?.city || '';\n    const province = car.esBranch?.state || car.esBranch?.region || car.esBranch?.province || '';\n    const location = [city, province].filter(Boolean).join(', ');\n\n    let fuel = fuelMap[car.fuelType] || String(car.fuelType || '');\n    let envLabel = normalizeLabel(car.emissionSticker);\n    // PHEV: un híbrido con etiqueta 0 Emisiones es enchufable (los HEV normales son ECO)\n    if (fuel === 'Híbrido' && envLabel === '0 Emisiones') fuel = 'Híbrido enchufable';\n\n    items.push({ json: {\n      id: `ah_${car.id}`,\n      portal: 'autohero',\n      url: `https://www.autohero.com/es/${car.carUrlTitle || 'coche'}/id/${car.id}/`,\n      title: `${car.manufacturer} ${car.model} ${car.subType || ''}`.trim(),\n      brand: car.manufacturer || '',\n      model: car.model || '',\n      version: `${car.subType || ''} ${car.subTypeExtra || ''}`.trim(),\n      price,\n      monthly_price: monthly,\n      year: car.builtYear || car.firstRegistrationYear || null,\n      mileage: car.mileage?.distance || null,\n      fuel: fuel,\n      transmission: gearMap[car.gearType] || '',\n      image_url: (car.mainImageUrl || '').replace('{size}', '768x432-'),\n      power_kw: car.kw || null,\n      power_cv: car.kw ? Math.round(car.kw * 1.35962) : null,\n      city,\n      province,\n      location,\n      dealer_name: car.esBranch?.name || '',\n      co2: car.co2Value ? String(car.co2Value) : '',\n      displacement: car.ccm ? String(car.ccm) : '',\n      consumption: car.fuelConsumption?.combined || null,\n      listing_type: 'compra',\n      seller_type: 'profesional',\n      body_type: '',\n      environmental_label: envLabel,\n      doors: car.numberOfDoors || null,\n      seats: car.numberOfSeats || null,\n      warranty_months: null,\n      traction: normalizeTraction(car.driveTrain),\n      next_itv: null,\n      scraped_at: now,\n      last_seen_at: now,\n      first_seen_at: now\n    }});\n  }\n}\n\nreturn items;\n"
      },
