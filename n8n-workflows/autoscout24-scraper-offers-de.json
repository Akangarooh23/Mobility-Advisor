        "batchSize": 1,
        "options": {}
      },
      "id": "as-a-loop",
      "name": "Loop: segmento por segmento",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        480,
        400
      ]
    },
    {
