{
  "buildCommand": "npm run build",
  "functions": {
    "api/billing.js": {
      "includeFiles": "node_modules/{pdfkit,@noble,fontkit,js-md5,linebreak,png-js,@swc,brotli,clone,dfa,fast-deep-equal,restructure,tiny-inflate,unicode-properties,unicode-trie,base64-js,pako}/**"
    },
    "api/billing-webhook.js": {
      "includeFiles": "node_modules/{pdfkit,@noble,fontkit,js-md5,linebreak,png-js,@swc,brotli,clone,dfa,fast-deep-equal,restructure,tiny-inflate,unicode-properties,unicode-trie,base64-js,pako}/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron-appointment-reminders",
      "schedule": "0 8 * * *"
    }
  ],

  "rewrites": [
    {
      "source": "/api/ping",
      "destination": "/api/billing?route=ping"
    },
    {
      "source": "/api/market-price",
      "destination": "/api/market?route=price"
    },
    {
      "source": "/api/marketplace-vo",
      "destination": "/api/market?route=vo"
    },
    {
      "source": "/api/workshops-nearby",
      "destination": "/api/workshops?route=nearby"
    },
    {
      "source": "/api/workshop-availability",
      "destination": "/api/workshops?route=availability"
    },
    {
      "source": "/api/billing-account",
      "destination": "/api/billing?route=account"
    },
    {
      "source": "/api/billing-checkout",
      "destination": "/api/billing?route=checkout"
    },
    {
      "source": "/api/billing-portal",
      "destination": "/api/billing?route=portal"
    },
    {
      "source": "/api/billing-webhook",
      "destination": "/api/billing-webhook"
    },
    {
      "source": "/api/invoice-pdf",
      "destination": "/api/billing?route=invoice-pdf"
    },
    {
      "source": "/api/user-saved",
      "destination": "/api/user?route=saved"
    },
    {
      "source": "/api/user-alerts",
      "destination": "/api/user?route=alerts"
    },
    {
      "source": "/api/user-preferences",
      "destination": "/api/user?route=preferences"
    },
    {
      "source": "/api/attachment-file",
      "destination": "/api/user?route=attachment-file"
    },
    {
      "source": "/api/leads",
      "destination": "/api/user?route=leads"
    },
    {
      "source": "/api/vehicle-publish",
      "destination": "/api/user?route=vehicle-publish"
    },
    {
      "source": "/api/viewing-request",
      "destination": "/api/user?route=viewing-request"
    },
    {
      "source": "/api/viewing-propose",
      "destination": "/api/user?route=viewing-propose"
    },
    {
      "source": "/api/viewing-confirm",
      "destination": "/api/user?route=viewing-confirm"
    },
    {
      "source": "/api/viewing-get",
      "destination": "/api/user?route=viewing-get"
    },
    {
      "source": "/api/funnel-event",
      "destination": "/api/user?route=funnel-event"
    },
    {
      "source": "/api/cron-appointment-reminders",
      "destination": "/api/user?route=cron-appointment-reminders"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/marketplace-vo/:id",
      "destination": "/api/market?route=og&id=:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
