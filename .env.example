GEMINI_API_KEY=AIzaSyxxxx

# Auth en SQL Server (opcional; si no se configura usa JSON local)
# AUTH_PROVIDER=sqlcmd-windows usa autenticación de Windows (SQLCMD -E)
# AUTH_PROVIDER=mssql usa usuario/contraseña SQL
AUTH_PROVIDER=local
MSSQL_SERVER=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true
SQLCMD_PATH=
AUTH_SESSION_TTL_HOURS=24
AUTH_SESSION_CLEANUP_PROBABILITY=0.2
AUTH_SESSION_SECRET=
AUTH_EXPOSE_RESET_CODE=false
AUTH_REQUIRE_EMAIL_DELIVERY=false
AUTH_RESET_REQUEST_WINDOW_MS=900000
AUTH_RESET_REQUEST_MAX_PER_EMAIL=3
AUTH_RESET_REQUEST_MAX_PER_IP=10
AUTH_RESET_CONFIRM_WINDOW_MS=600000
AUTH_RESET_CONFIRM_MAX_PER_EMAIL=8
AUTH_RESET_CONFIRM_MAX_PER_IP=20
AUTH_RESET_BACKOFF_BASE_MS=30000
AUTH_RESET_BACKOFF_MAX_MS=900000
AUTH_SECURITY_LOG_ENABLED=true
AUTH_SECURITY_STATUS_ENABLED=false

# Email real de alertas (opcional)
# Si no configuras esta clave, MoveAdvisor seguirá en modo local/simulado.
RESEND_API_KEY=
ALERT_EMAIL_FROM="MoveAdvisor <onboarding@resend.dev>"
ALERT_EMAIL_PROVIDER=resend
