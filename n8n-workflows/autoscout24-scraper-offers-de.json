    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Repartir las 45 marcas en 7 grupos (uno por dia de la semana) para no saturar disco/tiempo.\n// Cada dia procesa ~6-7 marcas x 14 tramos de precio. En 1 semana se cubre todo el catalogo.\nconst makes = [9,13,47,74,64,60,55,21,54,29,70,39,33,52,28,16360,65,73,46,31,16338,51802,38,15641,43,68,50,6,16415,37,57,51520,15525,67,66,48,19,20,16396,45,27,42,16355,35,14882];\nconst buckets = [[0,3000],[3000,5000],[5000,7000],[7000,9000],[9000,11000],[11000,13000],[13000,15000],[15000,18000],[18000,22000],[22000,27000],[27000,35000],[35000,50000],[50000,80000],[80000,99999999]];\nconst day = new Date().getDay(); // 0=domingo .. 6=sabado\nconst mine = makes.filter((mk, i) => i % 7 === day);\nconst out = [];\nfor (const mk of mine) { for (const b of buckets) { out.push({ json: { mk: mk, pf: b[0], pt: b[1] } }); } }\nreturn out;"
      },
      "id": "as-a-gen",
      "name": "Code: Generar segmentos (marca x precio)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        400
      ]
    },
    {
